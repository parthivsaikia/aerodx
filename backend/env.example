# Copy this to .env and edit as needed
APP_NAME=AeroDx - Lung Disease Detection API
APP_VERSION=1.0.0
DEBUG=true

# Frontend URLs (comma-separated in production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Storage paths (relative to project root)
UPLOAD_DIR=uploads
ML_MODELS_DIR=ml_models

# File limits
MAX_FILE_SIZE_MB=50

# Report branding
REPORT_TITLE=AeroDx Lung Disease Detection Report
HOSPITAL_NAME=AeroDx Medical Imaging
